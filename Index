<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Happy Birthday Mousumi!</title>
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@700&family=Playfair+Display:ital,wght@0,400;1,700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
    
    <style>
        :root {
            --rose-gold: #b76e79;
            --cream: #fff5f6;
            --deep-rose: #8e44ad;
        }

        body {
            margin: 0;
            background-color: var(--cream);
            font-family: 'Playfair Display', serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            overflow: hidden;
            text-align: center;
        }

        /* Ambient Floating Background Elements */
        .bg-circle {
            position: absolute;
            border-radius: 50%;
            background: rgba(183, 110, 121, 0.1);
            filter: blur(50px);
            z-index: -1;
            animation: float 15s infinite alternate ease-in-out;
        }

        @keyframes float {
            0% { transform: translate(0, 0); }
            100% { transform: translate(50px, 100px); }
        }

        .card {
            background: white;
            padding: 40px 25px;
            border-radius: 30px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.1);
            max-width: 85%;
            transform: translateY(20px);
            opacity: 0;
            animation: fadeInUp 1.2s forwards ease-out;
            border: 1px solid rgba(183, 110, 121, 0.2);
        }

        @keyframes fadeInUp {
            to { transform: translateY(0); opacity: 1; }
        }

        h1 {
            font-family: 'Dancing Script', cursive;
            font-size: 3.2rem;
            color: var(--rose-gold);
            margin-bottom: 10px;
        }

        p.subtitle {
            font-style: italic;
            color: #7f8c8d;
            letter-spacing: 2px;
            text-transform: uppercase;
            font-size: 0.8rem;
        }

        .main-message {
            font-size: 1.1rem;
            line-height: 1.8;
            color: #444;
            margin: 25px 0;
        }

        /* The Interactive Button */
        .btn-celebrate {
            background: linear-gradient(45deg, #b76e79, #f1a7b4);
            color: white;
            border: none;
            padding: 16px 35px;
            border-radius: 50px;
            font-size: 1rem;
            font-weight: bold;
            box-shadow: 0 8px 20px rgba(183, 110, 121, 0.4);
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .btn-celebrate:active {
            transform: scale(0.95);
        }

        /* Cake SVG Styling */
        .cake-icon {
            font-size: 4rem;
            margin-bottom: 10px;
            display: block;
            animation: bounce 2s infinite;
        }

        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
    </style>
</head>
<body>

    <div class="bg-circle" style="width: 300px; height: 300px; top: -50px; left: -50px;"></div>
    <div class="bg-circle" style="width: 400px; height: 400px; bottom: -100px; right: -50px; background: rgba(142, 68, 173, 0.05);"></div>

    <div class="card">
        <span class="cake-icon">🎂</span>
        <p class="subtitle">For an Incredible Woman</p>
        <h1>Happy Birthday, Mousumi</h1>
        <div class="main-message">
            To the world's most beautiful and loving Mother. <br>
            May your day be filled with the same <br>
            <strong>warmth and light</strong> you give us every day.
        </div>
        <button class="btn-celebrate" onclick="fireworks()">Tap for a Surprise</button>
    </div>

    <script>
        function fireworks() {
            // High-end confetti burst from the button
            var duration = 3 * 1000;
            var animationEnd = Date.now() + duration;
            var defaults = { startVelocity: 30, spread: 360, ticks: 60, zIndex: 0 };

            function randomInRange(min, max) {
              return Math.random() * (max - min) + min;
            }

            var interval = setInterval(function() {
              var timeLeft = animationEnd - Date.now();

              if (timeLeft <= 0) {
                return clearInterval(interval);
              }

              var particleCount = 50 * (timeLeft / duration);
              // since they fall down, start a bit higher than random
              confetti(Object.assign({}, defaults, { particleCount, origin: { x: randomInRange(0.1, 0.3), y: Math.random() - 0.2 } }));
              confetti(Object.assign({}, defaults, { particleCount, origin: { x: randomInRange(0.7, 0.9), y: Math.random() - 0.2 } }));
            }, 250);

            // Change button text after click
            document.querySelector('.btn-celebrate').innerText = "We Love You! ❤️";
        }

        // Automatic mini-burst on load
        window.onload = () => {
            confetti({
                particleCount: 100,
                spread: 70,
                origin: { y: 0.6 },
                colors: ['#b76e79', '#f1a7b4', '#ffffff']
            });
        };
    </script>
</body>
</html>
